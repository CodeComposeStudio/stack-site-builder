{
  "name": "stack-site-builder",
  "type": "module",
  "version": "1.16.1",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "description": "The engine behind the awesome-*-stack catalog sites: an Astro theme with the catalog/concepts/articles/slides/samples routes, components, styles and markdown pipeline. Sites provide content, taxonomy data and config.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeCompose7/stack-site-builder.git"
  },
  "files": [
    "index.mjs",
    "index.d.ts",
    "markdown.mjs",
    "src",
    "dev",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "pnpm --filter playground dev",
    "build": "pnpm --filter playground build",
    "check": "pnpm --filter playground check"
  },
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.mjs"
    },
    "./markdown": "./markdown.mjs",
    "./content": "./src/content.ts",
    "./pages/*": "./src/pages/*",
    "./components/*": "./src/components/*",
    "./layouts/*": "./src/layouts/*",
    "./lib/*": "./src/lib/*.ts",
    "./i18n/*": "./src/i18n/*.ts",
    "./styles/*": "./src/styles/*"
  },
  "peerDependencies": {
    "astro": "^5.7.0"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/rss": "^4.0.0",
    "@astrojs/sitemap": "^3.3.0",
    "@tailwindcss/vite": "^4.1.0",
    "markdown-it": "^14.2.0",
    "mermaid": "^11.15.0",
    "rehype-external-links": "^3.0.0",
    "rehype-slug": "^6.0.0",
    "remark-directive": "^4.0.0",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.1.0"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "astro": "^5.7.0",
    "typescript": "^6.0.3"
  }
}

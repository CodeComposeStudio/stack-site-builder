# Private-content settings (only needed when some entry has `private: true`).
# Copy to .env for local builds; in CI set these as repository secrets.
# NOTE: the SOURCE repo must be private too — .mdx files are plaintext; only
# the built output is encrypted. See docs/private-content-design.md.

# Users allowed to unlock private entries — "id:password", comma-separated.
# Passwords are PLAINTEXT here: use long passphrases unique to this site.
AAS_PRIVATE_USERS="alice:use-a-long-passphrase,bob:another-long-one"

# Stable secret the content key derives from. Sessions survive redeploys while
# it's unchanged; CHANGE it to force every device to log in again (do this
# whenever you remove a user).
AAS_PRIVATE_MASTER_SECRET="generate-one-long-random-string"

# Days a cached login lasts on a device (client-side hygiene; 0 = no expiry).
AAS_PRIVATE_SESSION_DAYS=30

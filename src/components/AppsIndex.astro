---
// The apps index — one wide card per product landing (icon, name, subtitle,
// meta description), the "pick an app" entry point the header's Apps link
// leads to. Cards mirror the cards-home style so the two read as one system.
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getAppLandings, appSlugOf } from '../lib/apps';
import { useTranslations, type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const apps = await getAppLandings(lang);
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const withBase = (p?: string) => (p && p.startsWith('/') ? base + p : p);
---

<section class="py-6">
  <h1 class="text-4xl font-bold tracking-tight">{t('apps.title')}</h1>
  <p class="mt-3 max-w-2xl text-lg text-[var(--aas-muted)]">{t('apps.tagline')}</p>
</section>

{apps.length === 0 && <p class="mt-8 text-[var(--aas-muted)]">{t('apps.empty')}</p>}

<div class="mt-6 flex flex-col gap-5">
  {
    apps.map((a) => (
      <a
        href={getRelativeLocaleUrl(lang, `apps/${appSlugOf(a)}/`)}
        class="aas-lift flex items-center gap-6 rounded-3xl border border-[var(--aas-border)] bg-[var(--aas-panel)] p-6 no-underline"
      >
        {a.data.icon && (
          <img src={withBase(a.data.icon)} alt="" class="h-20 w-20 shrink-0 rounded-[22%]" loading="lazy" />
        )}
        <span class="min-w-0">
          <span class="block text-xl font-semibold text-[var(--aas-text)]">{a.data.title}</span>
          {a.data.subtitle && (
            <span class="mt-1 block leading-relaxed text-[var(--aas-muted)]" set:html={a.data.subtitle} />
          )}
          {a.data.description && (
            <span class="mt-1 block text-sm leading-relaxed text-[var(--aas-muted)] opacity-75">
              {a.data.description}
            </span>
          )}
        </span>
      </a>
    ))
  }
</div>

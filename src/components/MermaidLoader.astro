---
// Renders any <pre class="mermaid"> on the page on the client, themed to match
// the site (colors pulled from our CSS variables), and re-renders when the
// theme changes. Include once on pages that contain Mermaid diagrams.
---

<script>
  // The self-contained browser bundle, NOT the package default: the default
  // entry (mermaid.core.mjs) keeps dayjs/d3 as bare CJS imports, which break
  // with a "does not provide an export named 'default'" SyntaxError in a
  // CONSUMING site's dev server — the theme lives in node_modules there, so
  // Vite serves the import chain raw without CJS interop. The esm.min bundle
  // inlines every dependency (relative-chunk imports only), so it loads the
  // same in dev and build.
  // @ts-expect-error — the bundled build ships no type mapping; same API.
  import mermaid from 'mermaid/dist/mermaid.esm.min.mjs';
  import { initOnReady } from '../lib/reinit';

  // Read the live site palette so Mermaid matches the current theme exactly.
  function palette() {
    const cs = getComputedStyle(document.documentElement);
    const v = (name: string) => cs.getPropertyValue(name).trim();
    return {
      bg: v('--aas-bg'),
      panel: v('--aas-panel'),
      text: v('--aas-text'),
      accent: v('--aas-accent'),
      border: v('--aas-border'),
      muted: v('--aas-muted'),
    };
  }

  function init() {
    const p = palette();
    mermaid.initialize({
      startOnLoad: false,
      securityLevel: 'strict',
      theme: 'base',
      themeVariables: {
        background: 'transparent',
        fontFamily: 'ui-sans-serif, system-ui, sans-serif',
        primaryColor: p.panel,
        primaryTextColor: p.text,
        primaryBorderColor: p.accent,
        nodeBorder: p.accent,
        mainBkg: p.panel,
        nodeTextColor: p.text,
        lineColor: p.muted,
        edgeLabelBackground: p.bg,
        clusterBkg: 'transparent',
        clusterBorder: p.muted,
        titleColor: p.text,
        secondaryColor: p.bg,
        tertiaryColor: p.bg,
      },
    });
  }

  // Authored `style X fill:#…` lines carry light-mode colors, and Mermaid's
  // HTML labels take their text color from the THEME variables — in dark mode
  // that pairs light text with the hardcoded light fills, unreadable. So in
  // dark mode we drop those fill styles and let the diagram render entirely
  // from the theme palette; light mode keeps the authored colors.
  function srcForTheme(src: string): string {
    if (document.documentElement.dataset.theme !== 'dark') return src;
    return src
      .split('\n')
      .filter((l) => !/^\s*style\s+\S+.*fill:#/.test(l))
      .join('\n');
  }

  async function renderAll() {
    const nodes = Array.from(document.querySelectorAll<HTMLElement>('pre.mermaid'));
    if (nodes.length === 0) return;
    for (const n of nodes) {
      if (!n.dataset.src) n.dataset.src = (n.textContent ?? '').trim();
      n.removeAttribute('data-processed');
      // textContent, not innerHTML: dataset.src is entity-DECODED source, so
      // injecting it as HTML would turn `<…>` in labels into live DOM (the
      // server-side escaping exists precisely to prevent that). Mermaid reads
      // the element's innerHTML and decodes entities itself.
      n.textContent = srcForTheme(n.dataset.src ?? '');
    }
    init();
    try {
      await mermaid.run({ nodes });
    } catch {
      /* leave the raw source visible on failure */
    }
  }

  // Re-runs after private-content decryption too (diagrams arrive with it).
  initOnReady(() => void renderAll());

  // Allow tab/version switches to re-render diagrams that were hidden (and thus
  // mis-sized) at first paint.
  (window as unknown as { __aasRenderMermaid?: () => void }).__aasRenderMermaid = renderAll;

  // Re-render diagrams (with fresh palette) when the theme toggles.
  let last = document.documentElement.dataset.theme;
  new MutationObserver(() => {
    const now = document.documentElement.dataset.theme;
    if (now !== last) {
      last = now;
      renderAll();
    }
  }).observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

  // A diagram inside a closed <details> renders at zero size; when the reveal
  // opens, re-render so it lays out correctly. `toggle` doesn't bubble — capture.
  document.addEventListener(
    'toggle',
    (e) => {
      const d = e.target as HTMLElement;
      if (d instanceof HTMLDetailsElement && d.open && d.querySelector('pre.mermaid')) renderAll();
    },
    true,
  );
</script>

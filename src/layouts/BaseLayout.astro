---
import '../styles/global.css';
import { site } from '@aas-data/site';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, languages, type Lang } from '../i18n/ui';
import LanguageSwitcher from '../components/LanguageSwitcher.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import BackToTop from '../components/BackToTop.astro';
// Resolved by the integration: the site's src/components/Footer.astro when it
// exists, the theme's DefaultFooter otherwise.
// @ts-expect-error -- virtual alias, no static types
import Footer from '@aas-footer';
import { getNavPages, pageSlugOf } from '../lib/pages';
import { getNavProducts, getTopProducts, productSlugOf } from '../lib/products';
import { homeTemplate } from '../lib/home';
import { sectionEnabled, type SectionKey } from '../lib/sections';
import { siteIcons } from '../lib/icons';
import { privateClientData } from '../lib/private';

// Whether the site has login users configured is a build-time fact (AAS_PRIVATE_*
// env), so the header login control renders in its final state instead of being
// revealed after a runtime fetch — a late reveal shifted the whole icon row on
// every navigation.
let authEnabled = false;
try {
  privateClientData();
  authEnabled = true;
} catch {
  /* no private env — control stays hidden */
}

interface Props {
  title: string;
  description?: string;
  lang: Lang;
  /** Locale-relative path of this page, e.g. '' (home) or 'stack/litellm/'. */
  path: string;
  /** Wider container — used by detail pages that have a right-rail TOC. */
  wide?: boolean;
  /** Private entries: ask crawlers not to index the gate page. */
  noindex?: boolean;
}

const { title, lang, path, wide = false, noindex = false } = Astro.props;
const t = useTranslations(lang);
// Collapse any authored line breaks (used for on-page wrapping) to a single
// space so the SEO meta description stays one clean line.
const description = (Astro.props.description ?? t('site.tagline')).replace(/\s*\n\s*/g, ' ');
const container = wide ? 'max-w-[81rem]' : 'max-w-[75rem]';

const home = getRelativeLocaleUrl(lang, '');
const base = import.meta.env.BASE_URL;

const baseNoSlash = base.replace(/\/$/, '');

// Header brand: `site.header = { logo?: '/path.png', logoInvert?: bool,
// name?: bool }`. A logo replaces the ⚡ bolt; `name: false` drops the
// wordmark (logo-only brand — the link keeps site.name as its aria-label).
const header = (site as { header?: { logo?: string; logoInvert?: boolean; name?: boolean } })
  .header;
const brandLogo = header?.logo;
const brandName = header?.name !== false;

// Home URL per locale, for the language auto-detect redirect on the root home.
const localeHomes = Object.fromEntries(
  (Object.keys(languages) as Lang[]).map((c) => [c, getRelativeLocaleUrl(c, '')]),
);
const isDefaultHome = path === '' && lang === 'en';

// Standalone pages (the `pages` collection) that opt into a header-nav link,
// e.g. an About/소개 page. Rendered as their own nav items alongside the
// built-in sections; the accessible label comes from the page's own frontmatter.
const navPages = await getNavPages(lang);
// Products that opt into their own header link (the collection's `nav`), plus
// the Products-index link, which appears once the locale has any product.
const navProducts = await getNavProducts(lang);
const hasProducts = (await getTopProducts(lang)).length > 0;
// The header's GitHub link — hidden for sites whose repo is private
// (`repoNav: false` in site.ts) or that declare no repoUrl at all.
const showRepoLink =
  !!site.repoUrl && (site as { repoNav?: boolean }).repoNav !== false;

// The header sections, as data — rendered twice from one source so the two
// layouts never drift: an icon-only row (≥sm) and a labelled dropdown menu
// (<sm, so a phone header stays to a few controls instead of a long icon run).
// `svg` is the icon's inner markup (drawn into a shared <svg> shell below).
const allNavItems: {
  href: string;
  label: string;
  svg: string;
  external?: boolean;
  keepFilters?: boolean;
  section?: SectionKey;
}[] = [
  // Browse anchors into the catalog home's category sections — it only makes
  // sense when the site keeps the catalog home template.
  ...(homeTemplate === 'catalog'
    ? [
        {
          href: `${home}#categories`,
          label: t('nav.browse'),
          keepFilters: true,
          svg: '<rect width="7" height="7" x="3" y="3" rx="1"/><rect width="7" height="7" x="14" y="3" rx="1"/><rect width="7" height="7" x="14" y="14" rx="1"/><rect width="7" height="7" x="3" y="14" rx="1"/>',
        },
      ]
    : []),
  ...(hasProducts
    ? [
        {
          href: getRelativeLocaleUrl(lang, 'products/'),
          label: t('nav.products'),
          section: 'products' as SectionKey,
          svg: '<rect x="2" y="4" width="20" height="16" rx="2"/><path d="M10 4v4"/><path d="M2 8h20"/><path d="M6 4v4"/>',
        },
      ]
    : []),
  {
    href: getRelativeLocaleUrl(lang, 'course/'),
    label: t('nav.courses'),
    section: 'courses',
    svg: '<path d="M21.42 10.922a1 1 0 0 0-.019-1.838L12.83 5.18a2 2 0 0 0-1.66 0L2.6 9.08a1 1 0 0 0 0 1.832l8.57 3.908a2 2 0 0 0 1.66 0z"/><path d="M22 10v6"/><path d="M6 12.5V16a6 3 0 0 0 12 0v-3.5"/>',
  },
  {
    href: getRelativeLocaleUrl(lang, 'paper/'),
    label: t('nav.papers'),
    section: 'papers' as SectionKey,
    svg: '<path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>',
  },
  {
    href: getRelativeLocaleUrl(lang, 'concept/'),
    label: t('nav.concepts'),
    section: 'concepts',
    svg: '<path d="M12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"/><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"/><path d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"/>',
  },
  {
    href: getRelativeLocaleUrl(lang, 'article/'),
    label: t('nav.blog'),
    section: 'articles',
    svg: '<path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/>',
  },
  {
    href: getRelativeLocaleUrl(lang, 'sample/'),
    label: t('nav.samples'),
    section: 'samples',
    svg: '<polyline points="4 17 10 11 4 5"/><line x1="12" x2="20" y1="19" y2="19"/>',
  },
  {
    href: getRelativeLocaleUrl(lang, 'slides/'),
    label: t('nav.slides'),
    section: 'slides',
    svg: '<path d="M2 3h20"/><path d="M21 3v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V3"/><path d="m7 21 5-5 5 5"/><path d="M12 12v9"/>',
  },
  {
    href: getRelativeLocaleUrl(lang, 'glossary/'),
    label: t('nav.glossary'),
    section: 'glossary',
    svg: '<path d="M12 7v14"/><path d="M3 18a1 1 0 0 1-1-1V4a1 1 0 0 1 1-1h5a4 4 0 0 1 4 4 4 4 0 0 1 4-4h5a1 1 0 0 1 1 1v13a1 1 0 0 1-1 1h-6a3 3 0 0 0-3 3 3 3 0 0 0-3-3z"/>',
  },
  ...navProducts.map((a) => ({
    href: getRelativeLocaleUrl(lang, `products/${productSlugOf(a)}/`),
    label: a.data.navLabel ?? a.data.title,
    section: 'products' as SectionKey,
    svg: '<rect width="14" height="20" x="5" y="2" rx="2" ry="2"/><path d="M12 18h.01"/>',
  })),
  ...navPages.map((p) => ({
    href: getRelativeLocaleUrl(lang, `${pageSlugOf(p)}/`),
    label: p.data.navLabel ?? p.data.title,
    section: 'pages' as SectionKey,
    svg: '<circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/>',
  })),
  ...(showRepoLink
    ? [
        {
          href: site.repoUrl,
          label: 'GitHub',
          external: true,
          svg: '<path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C4 2 3 2 3 2c-.3 1.15-.3 2.35 0 3.5A5.4 5.4 0 0 0 2 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/>',
        },
      ]
    : []),
];
// Drop the nav links for sections the site turned off (their routes aren't built).
const navItems = allNavItems.filter((item) => !item.section || sectionEnabled(item.section));
---

<!doctype html>
<html lang={lang} data-copy-label={t('code.copy')} data-copied-label={t('code.copied')}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="icon" {...(siteIcons.faviconType ? { type: siteIcons.faviconType } : {})} href={`${baseNoSlash}${siteIcons.favicon}`} />
    {siteIcons.appleTouch && <link rel="apple-touch-icon" href={`${baseNoSlash}${siteIcons.appleTouch}`} />}
    {siteIcons.manifest && <link rel="manifest" href={`${baseNoSlash}${siteIcons.manifest}`} />}
    {
      sectionEnabled('articles') && (
        <link
          rel="alternate"
          type="application/rss+xml"
          title={`${site.name} — ${t('blog.title')}`}
          href={getRelativeLocaleUrl(lang, 'rss.xml')}
        />
      )
    }
    {/* On the root (default-locale) home, send first-time visitors to the
        locale matching their browser — unless they've already picked one (the
        language switcher stores `aas:lang`). Runs before paint, no history entry. */}
    {
      isDefaultHome && (
        <script is:inline define:vars={{ curLang: lang, localeHomes }}>
          (function () {
            try {
              var supported = Object.keys(localeHomes);
              var target = localStorage.getItem('aas:lang');
              if (!target || supported.indexOf(target) === -1) {
                target = null;
                var navs = navigator.languages || [navigator.language || ''];
                for (var i = 0; i < navs.length; i++) {
                  var b = (navs[i] || '').toLowerCase().split('-')[0];
                  if (supported.indexOf(b) !== -1) {
                    target = b;
                    break;
                  }
                }
              }
              if (target && target !== curLang && localeHomes[target]) location.replace(localeHomes[target]);
            } catch (e) {}
          })();
        </script>
      )
    }
    {/* Set the theme before first paint to avoid a flash of the wrong theme. */}
    <script is:inline>
      (function () {
        try {
          var pref = localStorage.getItem('theme') || 'system';
          var dark =
            pref === 'dark' ||
            (pref === 'system' && window.matchMedia('(prefers-color-scheme: dark)').matches);
          document.documentElement.dataset.theme = dark ? 'dark' : 'light';
        } catch (e) {}
      })();
    </script>
    {/* Stamp html[data-aas-member] before paint when a login session exists,
        so member-only listing cards render without a flash (CSS keys off it). */}
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('aas:pk')) document.documentElement.dataset.aasMember = '1';
        } catch (e) {}
      })();
    </script>
    {/* Listing density (standard / gallery), persisted in localStorage. Gallery
        is the default; only an explicit 'grid' choice falls back to standard.
        Set before paint so the layout doesn't flash. */}
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('aas:view') !== 'grid')
            document.documentElement.dataset.view = 'gallery';
        } catch (e) {}
      })();
    </script>
  </head>
  <body class="min-h-screen">
    <header class="border-b border-[var(--aas-border)]">
      <div class:list={['mx-auto flex items-center justify-between gap-3 px-5 py-4', container]}>
        <a
          href={home}
          data-keep-filters
          aria-label={site.name}
          class="flex min-w-0 items-center gap-1.5 text-base font-bold tracking-tight whitespace-nowrap no-underline sm:text-lg"
        >
          {
            brandLogo ? (
              <img
                src={`${baseNoSlash}${brandLogo}`}
                alt=""
                class:list={['h-7 w-7 shrink-0 object-contain', header?.logoInvert && 'aas-icon-invert']}
              />
            ) : (
              <span aria-hidden="true">⚡</span>
            )
          }
          {/* Below 600px only the mark remains, so the narrow header never truncates the wordmark. */}
          {brandName && <span class="hidden truncate min-[600px]:inline">{site.name}</span>}
        </a>
        {/* Section links are icon-only (labels live in aria-label). On phones
            (<sm) they collapse into the labelled dropdown menu below, so the
            header stays to a few controls; from sm up the full icon row shows. */}
        <nav class="flex shrink-0 items-center gap-3 text-sm text-[var(--aas-muted)] sm:gap-4">
          <div class="hidden items-center gap-3 sm:flex sm:gap-4">
            {
              navItems.map((item) => (
                <a
                  href={item.href}
                  class="flex items-center no-underline hover:text-[var(--aas-text)]"
                  aria-label={item.label}
                  {...(item.keepFilters ? { 'data-keep-filters': true } : {})}
                  {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={item.svg} />
                </a>
              ))
            }
          </div>
          {/* Member login/logout for private content — rendered only when the
              build has login users configured, so the header never reflows. */}
          <details class="aas-menu relative" data-auth hidden={!authEnabled}>
            <summary
              class="flex cursor-pointer list-none items-center rounded-lg border border-[var(--aas-border)] px-2.5 py-1 text-[var(--aas-text)] select-none"
              aria-label={t('private.login')}
              title={t('private.login')}
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
            </summary>
            <div
              class="absolute right-0 z-20 mt-1 w-64 rounded-lg border border-[var(--aas-border)] bg-[var(--aas-panel)] p-3 shadow-lg"
            >
              <form data-auth-form class="flex flex-col gap-2">
                <input
                  name="id"
                  required
                  autocomplete="username"
                  placeholder={t('private.id')}
                  class="rounded-lg border border-[var(--aas-border)] bg-[var(--aas-bg)] px-3 py-1.5 text-sm text-[var(--aas-text)]"
                />
                <input
                  name="password"
                  type="password"
                  required
                  autocomplete="current-password"
                  placeholder={t('private.password')}
                  class="rounded-lg border border-[var(--aas-border)] bg-[var(--aas-bg)] px-3 py-1.5 text-sm text-[var(--aas-text)]"
                />
                <p data-auth-error hidden class="text-xs text-[var(--aas-accent)]">{t('private.error')}</p>
                <button
                  type="submit"
                  class="rounded-lg bg-[var(--aas-accent)] px-3 py-1.5 text-sm font-semibold text-white"
                >
                  {t('private.submit')}
                </button>
              </form>
              <button
                type="button"
                data-auth-logout
                hidden
                class="w-full rounded-lg border border-[var(--aas-border)] px-3 py-1.5 text-sm text-[var(--aas-text)] hover:bg-[var(--aas-tint)]"
              >
                🔓 {t('private.logout')}
              </button>
            </div>
          </details>
          <ThemeToggle lang={lang} />
          <LanguageSwitcher lang={lang} path={path} />
          <details class="aas-menu relative sm:hidden">
            <summary
              class="flex cursor-pointer list-none items-center rounded-lg border border-[var(--aas-border)] px-2.5 py-1 text-[var(--aas-text)] select-none"
              aria-label={t('nav.menu')}
              title={t('nav.menu')}
            >
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
            </summary>
            <ul
              class="absolute right-0 z-20 mt-1 min-w-[11rem] overflow-hidden rounded-lg border border-[var(--aas-border)] bg-[var(--aas-panel)] py-1 shadow-lg"
            >
              {
                navItems.map((item) => (
                  <li>
                    <a
                      href={item.href}
                      class="flex items-center gap-2.5 px-3 py-2 whitespace-nowrap text-[var(--aas-text)] no-underline hover:bg-[var(--aas-bg)]"
                      {...(item.keepFilters ? { 'data-keep-filters': true } : {})}
                      {...(item.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                    >
                      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="shrink-0 text-[var(--aas-muted)]" set:html={item.svg} />
                      <span>{item.label}</span>
                    </a>
                  </li>
                ))
              }
            </ul>
          </details>
        </nav>
      </div>
    </header>

    <style>
      /* Hide the default <details> disclosure triangle on the mobile menu
         (Safari needs the -webkit rule even with list-style: none). */
      .aas-menu > summary::-webkit-details-marker {
        display: none;
      }
    </style>

    <main class:list={['mx-auto px-5 py-10', container]}>
      <slot />
    </main>

    <Footer lang={lang} />

    <BackToTop lang={lang} />

    <script>
      import {
        hasSession,
        clearSession,
        loginWithCredentials,
        type AuthData,
      } from '../lib/private-client';

      // Header member login/logout: visibility is decided at build time (the
      // control renders hidden on sites without login users) — the fetch only
      // wires the login form with the user table from /aas-auth.json.
      const authCtrl = document.querySelector<HTMLDetailsElement>('[data-auth]');
      if (authCtrl && !authCtrl.hidden) {
        (async () => {
          try {
            const base = import.meta.env.BASE_URL.replace(/\/$/, '');
            const res = await fetch(`${base}/aas-auth.json`);
            const data = (await res.json()) as { enabled: boolean } & AuthData;
            if (!data.enabled) return;
            const form = authCtrl.querySelector<HTMLFormElement>('[data-auth-form]')!;
            const logoutBtn = authCtrl.querySelector<HTMLButtonElement>('[data-auth-logout]')!;
            const errorEl = authCtrl.querySelector<HTMLElement>('[data-auth-error]')!;
            const sync = () => {
              const on = hasSession(data.days);
              form.hidden = on;
              logoutBtn.hidden = !on;
            };
            sync();
            logoutBtn.addEventListener('click', () => {
              clearSession();
              location.reload();
            });
            form.addEventListener('submit', async (e) => {
              e.preventDefault();
              errorEl.hidden = true;
              const fd = new FormData(form);
              const ok = await loginWithCredentials(
                data,
                String(fd.get('id') ?? ''),
                String(fd.get('password') ?? ''),
              );
              if (ok) location.reload();
              else errorEl.hidden = false;
            });
          } catch {
            /* endpoint unavailable — control stays hidden */
          }
        })();
      }

      import { initOnReady } from '../lib/reinit';

      // Clicking a heading's "#" anchor copies that section's URL to the
      // clipboard (and updates the address bar) instead of just navigating.
      document.addEventListener('click', (e) => {
        const anchor = (e.target as HTMLElement).closest<HTMLAnchorElement>('a.aas-anchor');
        if (!anchor) return;
        e.preventDefault();
        const hash = anchor.getAttribute('href') ?? '';
        const url = location.origin + location.pathname + location.search + hash;
        history.replaceState(null, '', hash);
        navigator.clipboard?.writeText(url).catch(() => {});
        anchor.classList.add('copied');
        setTimeout(() => anchor.classList.remove('copied'), 1200);
      });

      // Mount a copy-to-clipboard button on every code block: README/overview
      // prose (.prose pre), the file viewer (.aas-projfile), and the Code tab
      // (.aas-code). The button is pinned to a non-scrolling host so it stays in
      // place on long, horizontally-scrolling code. Re-runs after private-content
      // decryption (mount() skips hosts that already have a button).
      initOnReady(function mountCopyButtons() {
        const LABEL = document.documentElement.dataset.copyLabel || 'Copy code';
        const DONE = document.documentElement.dataset.copiedLabel || 'Copied';
        const COPY_ICON =
          '<svg class="aas-ico-copy" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="13" height="13" x="9" y="9" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>';
        const CHECK_ICON =
          '<svg class="aas-ico-check" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>';

        function wrap(el: Element): HTMLElement {
          const w = document.createElement('div');
          w.className = 'aas-copyhost';
          el.parentNode?.insertBefore(w, el);
          w.appendChild(el);
          return w;
        }

        function mount(source: HTMLElement, host: HTMLElement) {
          if (host.querySelector(':scope > .aas-copy-btn')) return; // already mounted
          host.classList.add('aas-copyhost');
          const btn = document.createElement('button');
          btn.type = 'button';
          btn.className = 'aas-copy-btn';
          btn.setAttribute('aria-label', LABEL);
          btn.title = LABEL;
          btn.innerHTML = COPY_ICON + CHECK_ICON;
          let timer = 0;
          btn.addEventListener('click', () => {
            const text = source.innerText.replace(/\n$/, '');
            navigator.clipboard?.writeText(text).then(() => {
              btn.classList.add('copied');
              btn.setAttribute('aria-label', DONE);
              window.clearTimeout(timer);
              timer = window.setTimeout(() => {
                btn.classList.remove('copied');
                btn.setAttribute('aria-label', LABEL);
              }, 1400);
            });
          });
          host.appendChild(btn);
        }

        // Prose code blocks (READMEs, overviews, articles): wrap each <pre>.
        document
          .querySelectorAll<HTMLElement>('.prose pre:not(.mermaid)')
          .forEach((pre) => mount(pre, wrap(pre)));
        // Code tab: the .aas-code div is the scroll container — wrap it.
        document
          .querySelectorAll<HTMLElement>('.aas-code')
          .forEach((el) => mount(el, wrap(el)));
        // File viewer: anchor the button on the figure (above the scroll area).
        document.querySelectorAll<HTMLElement>('.aas-projfile').forEach((el) => {
          const fig = el.closest('figure');
          mount(el, (fig as HTMLElement) ?? wrap(el));
        });
      });

      // Close any open <details> dropdown when clicking outside it (or on Esc).
      // Only nav dropdowns — leave file-tree folders (.aas-tree-dir) and prose
      // content reveals (inside .prose, e.g. "구체적인 예시") alone; those toggle
      // only via their own summary.
      const isDropdown = (d: Element) => !d.closest('.aas-tree-dir') && !d.closest('.prose');
      document.addEventListener('click', (e) => {
        const target = e.target as Node;
        document.querySelectorAll<HTMLDetailsElement>('details[open]').forEach((d) => {
          if (isDropdown(d) && !d.contains(target)) d.open = false;
        });
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape')
          document
            .querySelectorAll<HTMLDetailsElement>('details[open]')
            .forEach((d) => isDropdown(d) && (d.open = false));
      });
    </script>
  </body>
</html>

{
  "extends": "astro/tsconfigs/strict",
  // Editor-time config. The theme is site-agnostic: `@aas-data/*` resolves to
  // whatever site is being built (the integration sets a Vite alias). For the
  // editor/typechecker we point it at the in-repo playground site.
  "include": ["src/**/*", "playground/.astro/types.d.ts"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@aas-data/*": ["playground/src/data/*"],
      "@assets/*": ["playground/src/assets/*"]
    }
  }
}
